# ─── Clerk (Authentication) ───────────────────────────────────────────────────
# https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_

# ─── Supabase (Database + Storage) ───────────────────────────────────────────
# https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── Sanity (CMS) ─────────────────────────────────────────────────────────────
# https://www.sanity.io/manage → your project → API
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# https://resend.com/api-keys
# Note: Resend API keys are server-side only — use a Supabase Edge Function
# or similar to call Resend; never expose this key in the frontend bundle.
RESEND_API_KEY=re_
